# Database (Supabase Postgres — use the "Connection pooler" URI for serverless/transient workloads)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR-PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# Resend (transactional emails)
RESEND_API_KEY=re_...

# OpenRouter (DeepSeek AI for matching & enrichment)
OPENROUTER_API_KEY=sk-or-...

# Aides et Territoires
AIDES_ET_TERRITOIRES_API_KEY=

# Admin access (protects /data-quality and other admin routes)
ADMIN_TOKEN=change-me-to-a-long-random-value
VITE_ADMIN_TOKEN=same-as-ADMIN_TOKEN

# Legacy / optional
N8N_WEBHOOK_URL=

# Puppeteer (set in Dockerfile on Railway, leave empty locally to use bundled Chrome)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
